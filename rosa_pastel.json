    "lyrics": [
    { "time": 24.8, "text": "Sí, yo quería ser esa mujer" },
    { "time": 28.69, "text": "La madre de tus hijos" },
    { "time": 31.42, "text": "Y juntos caminar hacia el altar" },
    { "time": 36.29, "text": "Directo hacia la muerte" },

    { "time": 39.50, "text": "Y al final, ni hablar" },
    { "time": 44.04, "text": "Los dos nos destruimos" },
    { "time": 46.86, "text": "Y al final, ¿qué tal?" },
    { "time": 51.75, "text": "Tú y yo ya no existimos" },

    { "time": 53.55, "text": "No, no quiero ser esa mujer" },
    { "time": 58.89, "text": "Ella se fue a un abismo" },
    { "time": 61.3, "text": "Y tú no eres aquel que prometió" },
    { "time": 66.4, "text": "Sería mi superhéroe" },
    { "time": 68.81, "text": "¿Y qué? Todo acabó, no queda más" },
    { "time": 73.92, "text": "Seremos dos extraños" },
    { "time": 76.4, "text": "Yo te olvidaré, me olvidarás" },
    { "time": 81.73, "text": "Hasta nunca" },

    { "time": 91.61, "text": "¿Y dónde quedó ese botón" },
    { "time": 95.56, "text": "Que lleva a la felicidad?" },
    { "time": 99.97, "text": "Luna de miel, rosa pastel" },
    { "time": 103.37, "text": "Clichés y tonterías" },

    { "time": 106.78, "text": "Y al final, ni hablar" },
    { "time": 111.19, "text": "Los dos nos destruimos" },
    { "time": 114.04, "text": "Y al final, ¿qué tal?" },
    { "time": 118.47, "text": "Tú y yo ya no existimos" },

    { "time": 121.8, "text": "No, no quiero ser esa mujer" },
    { "time": 125.44, "text": "Ella se fue a un abismo" },
    { "time": 128.69, "text": "Y tú no eres aquel que prometió" },
    { "time": 134.62, "text": "Sería mi superhéroe" },
    { "time": 136.72, "text": "¿Y qué? Todo acabó, no queda más" },
    { "time": 141.97, "text": "Seremos dos extraños" },
    { "time": 144.83, "text": "Yo te olvidaré, me olvidarás" },
    { "time": 149.31, "text": "Hasta nunca" },

    { "time": 166.19, "text": "Ta, ta, ta" },
    { "time": 170.51, "text": "Ta, ta" },
    { "time": 171.15, "text": "Ta-Tara, ta, ta, ta" },
    { "time": 174.09, "text": "Ta, ta, ta, ta" },
    { "time": 179.53, "text": "Ta, ta, ta" }
]
