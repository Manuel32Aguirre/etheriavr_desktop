    "lyrics": [
    { "time": 13.18, "text": "Stars shining bright above you" },
    { "time": 18.87, "text": "Night breezes seem to whisper \"I love you\"" },
    { "time": 24.56, "text": "Birds singin' in the sycamore trees" },
    { "time": 30.66, "text": "Dream a little dream of me" },

    { "time": 38.94, "text": "Say \"Night-ie night\" and kiss me" },
    { "time": 44.63, "text": "Just hold me tight and tell me you'll miss me" },
    { "time": 50.32, "text": "While I'm alone and blue as can be" },
    { "time": 57.43, "text": "Dream a little dream of me" },

    { "time": 62.50, "text": "Stars fading but I linger on, dear" },
    { "time": 70.40, "text": "Still craving your kiss" },
    { "time": 76.09, "text": "I'm longing to linger 'til dawn, dear" },
    { "time": 82.78, "text": "Just saying this" },

    { "time": 88.47, "text": "Sweet dreams 'til sunbeams find you" },
    { "time": 94.16, "text": "Sweet dreams that leave all worries behind you" },
    { "time": 100.85, "text": "But in your dreams, whatever they be" },
    { "time": 105.95, "text": "Dream a little dream of me" },

    { "time": 137.30, "text": "Stars fading but I linger on, dear" },
