    "lyrics": [
        {
            "time": 13.18,
            "text": "Stars shining bright above you"
        },
        {
            "time": 18.87,
            "text": "Night breezes seem to whisper \"I love you\""
        },
        {
            "time": 24.56,
            "text": "Birds singin' in the sycamore trees"
        },
        {
            "time": 30.66,
            "text": "Dream a little dream of me"
        },
        {
            "time": 38.94,
            "text": "Say \"Night-ie night\" and kiss me"
        },
        {
            "time": 44.63,
            "text": "Just hold me tight and tell me you'll miss me"
        },
        {
            "time": 50.32,
